# ─── Server ───────────────────────────────────────────────
PORT=8080
JWT_SECRET=change-me-to-a-strong-random-string

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgres://watchlist:watchlist@localhost:5432/watchlist?sslmode=disable
REDIS_URL=redis://localhost:6379

# ─── Data APIs ────────────────────────────────────────────
# Polygon.io (free tier: 5 req/min, OHLCV data)
POLYGON_API_KEY=

# Alpha Vantage (free tier: 5 req/min, fundamentals)
ALPHA_VANTAGE_API_KEY=

# Finnhub (free tier: 60 req/min, news + earnings calendar)
FINNHUB_API_KEY=

# NewsAPI (optional, supplementary headlines)
NEWS_API_KEY=

# ─── LLM for thesis generation ──────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=

# ─── Scoring ─────────────────────────────────────────────
# Extra tickers beyond default universe (comma-separated)
# UNIVERSE_LIST=PLTR,COIN,SNOW
MAX_PER_SECTOR=5
LIST_SIZE=25

# ─── Risk ────────────────────────────────────────────────
# Paper mode: all output tagged [PAPER], no real trade implications
PAPER_MODE_ONLY=true
